# Supabase Configuration
# Replace with your own Supabase project credentials
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: fixed back URL for Mercado Pago subscriptions (must be HTTPS)
# If not set, window.location.origin will be used
VITE_MERCADO_PAGO_BACK_URL=https://your-domain.com/dashboard
